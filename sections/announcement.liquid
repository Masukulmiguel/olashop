{% if section.settings.text != blank %}
<div class="announcement-bar" style="background: {{ section.settings.bg_color }};">
  <div class="container">
    <p class="announcement-text" style="color: {{ section.settings.text_color }};">
      {% if section.settings.link != blank %}
        <a href="{{ section.settings.link }}" style="color: {{ section.settings.text_color }};">{{ section.settings.text }}</a>
      {% else %}
        {{ section.settings.text }}
      {% endif %}
    </p>
  </div>
</div>
{% endif %}

<style>
  .announcement-bar {
    padding: 10px 0;
    text-align: center;
  }
  .announcement-text {
    font-size: 13px;
    font-weight: 500;
    margin: 0;
    letter-spacing: 0.5px;
  }
  .announcement-text a {
    text-decoration: underline;
  }
</style>

{% schema %}
{
  "name": "Barra de Aviso",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Texto",
      "default": "Frete grátis em compras acima de 50€"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link (opcional)"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Cor de fundo",
      "default": "#e74c3c"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Cor do texto",
      "default": "#ffffff"
    }
  ]
}
{% endschema %}
