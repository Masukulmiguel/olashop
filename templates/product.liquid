<div class="product-page">
  <div class="container">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="separator">/</span>
      {% if product.collections.first %}
        <a href="{{ product.collections.first.url }}">{{ product.collections.first.title }}</a>
        <span class="separator">/</span>
      {% endif %}
      <span class="current">{{ product.title }}</span>
    </nav>

    <div class="product-grid">
      <div class="product-images">
        <div class="product-main-image" id="ProductMainImage">
          <img src="{{ product.featured_image | img_url: 'large' }}" alt="{{ product.title | escape }}" id="ProductImage">
          {% if product.compare_at_price > product.price %}
            {% assign discount = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price %}
            <span class="product-badge sale" style="position: absolute; top: 16px; left: 16px; background: var(--color-gradient-accent); color: #fff; padding: 8px 18px; border-radius: var(--radius-full); font-size: 14px; font-weight: 700;">-{{ discount }}%</span>
          {% endif %}
          {% unless product.available %}
            <span class="product-badge sold-out" style="position: absolute; top: 16px; right: 16px; background: var(--color-primary); color: #fff; padding: 8px 18px; border-radius: var(--radius-full); font-size: 14px; font-weight: 700;">Esgotado</span>
          {% endunless %}
        </div>
        {% if product.images.size > 1 %}
          <div class="product-thumbnails">
            {% for image in product.images %}
              <button class="thumbnail {% if forloop.first %}active{% endif %}" data-image="{{ image | img_url: 'large' }}">
                <img src="{{ image | img_url: 'compact' }}" alt="{{ image.alt | escape }}">
              </button>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <div class="product-info">
        {% if product.vendor != blank %}
          <div class="product-vendor" style="font-size: 13px; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 8px;">{{ product.vendor }}</div>
        {% endif %}

        <h1 class="product-title">{{ product.title }}</h1>

        <div class="product-rating" style="display: flex; align-items: center; gap: 10px; margin-bottom: 20px;">
          <div class="stars" style="display: flex; gap: 2px;">
            {% for i in (1..5) %}
              <svg width="18" height="18" viewBox="0 0 24 24" fill="{% if i <= 4 %}#fdcb6e{% else %}none{% endif %}" stroke="#fdcb6e" stroke-width="1.5">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            {% endfor %}
          </div>
          <span style="font-size: 14px; color: var(--color-text-light);">(4.0) · 12 avaliações</span>
        </div>

        {% if product.compare_at_price > product.price %}
          <div class="product-price sale" style="display: flex; align-items: baseline; gap: 12px; margin-bottom: 24px;">
            <span class="current-price" style="font-size: 32px; font-weight: 800; color: var(--color-accent);">{{ product.price | money }}</span>
            <span class="compare-price" style="text-decoration: line-through; color: var(--color-text-muted); font-size: 22px; font-weight: 400;">{{ product.compare_at_price | money }}</span>
            {% assign savings = product.compare_at_price | minus: product.price %}
            <span style="background: rgba(0, 184, 148, 0.1); color: var(--color-success); padding: 4px 12px; border-radius: var(--radius-full); font-size: 13px; font-weight: 600;">Poupa {{ savings | money }}</span>
          </div>
        {% else %}
          <div class="product-price" style="font-size: 32px; font-weight: 800; color: var(--color-primary); margin-bottom: 24px;">{{ product.price | money }}</div>
        {% endif %}

        {% if product.description != blank %}
          <div class="product-description" style="color: var(--color-text-light); line-height: 1.8; margin-bottom: 32px; padding-bottom: 32px; border-bottom: 1px solid var(--color-border);">{{ product.description }}</div>
        {% endif %}

        <form action="/cart/add" method="post" class="product-form" id="ProductForm">
          {% if product.variants.size > 1 %}
            <div class="variant-selector">
              <label for="ProductSelect">{{ product.options.first }}</label>
              <select id="ProductSelect" name="id">
                {% for variant in product.variants %}
                  <option value="{{ variant.id }}" {% if variant == product.selected_or_first_available_variant %}selected{% endif %} {% unless variant.available %}disabled{% endunless %}>
                    {{ variant.title }} - {% if variant.available %}{{ variant.price | money }}{% else %}Esgotado{% endif %}
                  </option>
                {% endfor %}
              </select>
            </div>
          {% else %}
            <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
          {% endif %}

          <div class="quantity-selector">
            <button type="button" class="qty-btn minus" aria-label="Diminuir quantidade">-</button>
            <input type="number" name="quantity" value="1" min="1" class="qty-input" aria-label="Quantidade">
            <button type="button" class="qty-btn plus" aria-label="Aumentar quantidade">+</button>
          </div>

          <div style="display: flex; gap: 12px;">
            <button type="submit" class="btn btn-primary btn-add-to-cart" style="flex: 1;" {% unless product.available %}disabled{% endunless %}>
              {% if product.available %}
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
                  <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
                </svg>
                Adicionar ao Carrinho
              {% else %}
                Esgotado
              {% endif %}
            </button>
            <button type="button" class="btn btn-outline" style="padding: 16px 20px;" aria-label="Adicionar aos favoritos">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
              </svg>
            </button>
          </div>
        </form>

        {% if product.type != blank %}
          <div class="product-type" style="font-size: 14px; color: var(--color-text-light); margin-top: 20px;">
            <strong>Tipo:</strong> {{ product.type }}
          </div>
        {% endif %}

        <div class="product-share" style="margin-top: 24px; padding-top: 24px; border-top: 1px solid var(--color-border);">
          <span class="share-label">Partilhar:</span>
          <div class="share-buttons">
            <a href="https://www.facebook.com/sharer/sharer.php?u={{ shop.url | append: product.url }}" target="_blank" class="share-btn" aria-label="Partilhar no Facebook">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
            <a href="https://twitter.com/intent/tweet?url={{ shop.url | append: product.url }}" target="_blank" class="share-btn" aria-label="Partilhar no Twitter">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/></svg>
            </a>
            <a href="https://wa.me/?text={{ product.title | url_encode }}%20{{ shop.url | append: product.url }}" target="_blank" class="share-btn" aria-label="Partilhar no WhatsApp">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 24px 0;
    font-size: 14px;
    color: var(--color-text-light);
  }

  .breadcrumb a {
    color: var(--color-text-light);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .breadcrumb a:hover {
    color: var(--color-accent);
  }

  .breadcrumb .separator {
    color: var(--color-text-muted);
  }

  .breadcrumb .current {
    color: var(--color-text);
    font-weight: 500;
  }

  .product-main-image {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: #fff;
    box-shadow: var(--shadow-md);
  }

  .product-main-image img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .product-main-image:hover img {
    transform: scale(1.03);
  }
</style>