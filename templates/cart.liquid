<div class="cart-page">
  <div class="container">
    <h1 class="cart-title">Meu Carrinho</h1>

    {% if cart.item_count > 0 %}
      <form action="/cart" method="post" class="cart-form">
        <div class="cart-items">
          {% for item in cart.items %}
            <div class="cart-item" data-variant-id="{{ item.variant.id }}">
              <div class="cart-item-image">
                <img src="{{ item.image | img_url: 'medium' }}" alt="{{ item.title | escape }}">
              </div>
              <div class="cart-item-info">
                <a href="{{ item.url }}" class="cart-item-title">{{ item.product.title }}</a>
                {% unless item.variant.title == 'Default Title' %}
                  <div class="cart-item-variant">{{ item.variant.title }}</div>
                {% endunless %}
                <div class="cart-item-price">{{ item.price | money }}</div>
              </div>
              <div class="cart-item-quantity">
                <button type="button" class="qty-btn minus" aria-label="Diminuir quantidade">-</button>
                <input type="number" name="updates[]" value="{{ item.quantity }}" min="0" class="qty-input" aria-label="Quantidade">
                <button type="button" class="qty-btn plus" aria-label="Aumentar quantidade">+</button>
              </div>
              <div class="cart-item-total">{{ item.line_price | money }}</div>
              <button type="button" class="cart-item-remove" aria-label="Remover item" data-variant-id="{{ item.variant.id }}">&times;</button>
            </div>
          {% endfor %}
        </div>

        <div class="cart-footer">
          <div class="cart-notes">
            <label for="CartNote">Notas do pedido:</label>
            <textarea name="note" id="CartNote" rows="3">{{ cart.note }}</textarea>
          </div>
          <div class="cart-summary">
            <div class="cart-subtotal">
              <span>Subtotal:</span>
              <span>{{ cart.total_price | money }}</span>
            </div>
            <div class="cart-shipping-note">Frete calculado no checkout</div>
            <button type="submit" name="checkout" class="btn btn-primary btn-checkout">
              Finalizar Compra
            </button>
          </div>
        </div>
      </form>
    {% else %}
      <div class="cart-empty">
        <div class="cart-empty-icon">
          <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
          </svg>
        </div>
        <h2>Seu carrinho está vazio</h2>
        <p>Continue comprando para encontrar produtos incríveis!</p>
        <a href="/" class="btn btn-primary">Continuar Comprando</a>
      </div>
    {% endif %}
  </div>
</div>
