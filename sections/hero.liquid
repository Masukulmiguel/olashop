<div class="hero-section">
  <div class="hero-image">
    <img src="{{ 'banner.png' | asset_url }}" alt="OlaShop">
  </div>
  <div class="hero-overlay" style="background: {{ section.settings.overlay_color }};"></div>
  <div class="hero-particles"></div>
  <div class="hero-content container">
    <div class="hero-logo animate-fade-in-up">
      <img src="{{ 'logo.png' | asset_url }}" alt="{{ shop.name }}">
    </div>
    {% if section.settings.subtitle != blank %}
      <p class="hero-subtitle animate-fade-in-up delay-1">{{ section.settings.subtitle }}</p>
    {% endif %}
    {% if section.settings.title != blank %}
      <h1 class="hero-title animate-fade-in-up delay-2">{{ section.settings.title }}</h1>
    {% endif %}
    {% if section.settings.text != blank %}
      <p class="hero-text animate-fade-in-up delay-3">{{ section.settings.text }}</p>
    {% endif %}
    <div class="hero-buttons animate-fade-in-up delay-4">
      {% if section.settings.button_label != blank %}
        <a href="{{ section.settings.button_url | default: '/collections/all' }}" class="btn btn-hero">
          {{ section.settings.button_label }}
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      {% endif %}
      {% if section.settings.button2_label != blank %}
        <a href="{{ section.settings.button2_url }}" class="btn btn-hero-outline">
          {{ section.settings.button2_label }}
        </a>
      {% endif %}
    </div>
  </div>
</div>

<style>
  .hero-section {
    position: relative;
    min-height: 600px;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    animation: zoomOut 20s ease-in-out infinite alternate;
  }

  @keyframes zoomOut {
    from { transform: scale(1.1); }
    to { transform: scale(1); }
  }

  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: {{ section.settings.overlay_opacity | default: 0.4 }};
    background: linear-gradient(135deg, rgba(26, 26, 46, 0.9) 0%, rgba(233, 69, 96, 0.7) 100%);
  }

  .hero-particles {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image: 
      radial-gradient(2px 2px at 20px 30px, rgba(255,255,255,0.3), transparent),
      radial-gradient(2px 2px at 40px 70px, rgba(255,255,255,0.2), transparent),
      radial-gradient(2px 2px at 50px 160px, rgba(255,255,255,0.3), transparent),
      radial-gradient(2px 2px at 90px 40px, rgba(255,255,255,0.2), transparent),
      radial-gradient(2px 2px at 130px 80px, rgba(255,255,255,0.3), transparent),
      radial-gradient(2px 2px at 160px 120px, rgba(255,255,255,0.2), transparent);
    background-repeat: repeat;
    background-size: 200px 200px;
    animation: twinkle 5s ease-in-out infinite;
    opacity: 0.5;
  }

  @keyframes twinkle {
    0%, 100% { opacity: 0.5; }
    50% { opacity: 0.8; }
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 700px;
    padding: 100px 24px;
  }

  .hero-logo {
    margin-bottom: 24px;
  }

  .hero-logo img {
    max-height: 90px;
    width: auto;
    filter: drop-shadow(0 4px 20px rgba(0,0,0,0.3));
  }

  /* Animation Classes */
  .animate-fade-in-up {
    opacity: 0;
    transform: translateY(40px);
    animation: fadeInUp 0.8s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }

  .delay-1 { animation-delay: 0.2s; }
  .delay-2 { animation-delay: 0.4s; }
  .delay-3 { animation-delay: 0.6s; }
  .delay-4 { animation-delay: 0.8s; }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(40px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-subtitle {
    font-size: 15px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 4px;
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: 18px;
    display: inline-block;
    padding: 8px 20px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-full);
    backdrop-filter: blur(10px);
  }

  .hero-title {
    font-size: 58px;
    font-weight: 800;
    color: #ffffff;
    line-height: 1.1;
    margin-bottom: 24px;
    letter-spacing: -1px;
    text-shadow: 0 4px 30px rgba(0,0,0,0.3);
  }

  .hero-text {
    font-size: 19px;
    color: rgba(255, 255, 255, 0.9);
    line-height: 1.7;
    margin-bottom: 40px;
    max-width: 550px;
  }

  .hero-buttons {
    display: flex;
    gap: 18px;
    flex-wrap: wrap;
  }

  .btn-hero {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: #ffffff;
    color: var(--color-primary);
    padding: 18px 40px;
    border-radius: var(--radius-full);
    text-decoration: none;
    font-weight: 700;
    font-size: 16px;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 8px 30px rgba(0,0,0,0.2);
    position: relative;
    overflow: hidden;
  }

  .btn-hero::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(233, 69, 96, 0.1), transparent);
    transition: left 0.5s;
  }

  .btn-hero:hover {
    transform: translateY(-4px) scale(1.02);
    box-shadow: 0 12px 40px rgba(0,0,0,0.3);
    background: var(--color-accent);
    color: #fff;
  }

  .btn-hero:hover::before {
    left: 100%;
  }

  .btn-hero svg {
    transition: transform 0.3s ease;
  }

  .btn-hero:hover svg {
    transform: translateX(5px);
  }

  .btn-hero-outline {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    border: 2px solid rgba(255, 255, 255, 0.8);
    color: #ffffff;
    padding: 18px 40px;
    border-radius: var(--radius-full);
    text-decoration: none;
    font-weight: 600;
    font-size: 16px;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    backdrop-filter: blur(10px);
    background: rgba(255, 255, 255, 0.1);
  }

  .btn-hero-outline:hover {
    background: #ffffff;
    color: var(--color-primary);
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.2);
    border-color: #ffffff;
  }

  @media (max-width: 768px) {
    .hero-section { min-height: 500px; }
    .hero-title { font-size: 36px; }
    .hero-text { font-size: 16px; }
    .hero-content { padding: 80px 16px; }
    .hero-subtitle { font-size: 12px; letter-spacing: 2px; padding: 6px 16px; }
    .btn-hero, .btn-hero-outline { padding: 14px 28px; font-size: 14px; }
  }
</style>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "Bem-vindo à OlaShop"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Encontre os Melhores Produtos"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Texto",
      "default": "Produtos de qualidade com os melhores preços. Entrega rápida e segura."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Texto do botão principal",
      "default": "Ver Produtos"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "URL do botão principal"
    },
    {
      "type": "text",
      "id": "button2_label",
      "label": "Texto do botão 2"
    },
    {
      "type": "url",
      "id": "button2_url",
      "label": "URL do botão 2"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Cor do texto",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "btn_color",
      "label": "Cor do botão",
      "default": "#e94560"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Cor do overlay",
      "default": "#1a1a2e"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Opacidade do overlay",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0.4
    }
  ],
  "presets": [
    {
      "name": "Hero Banner",
      "category": "Imagem"
    }
  ]
}
{% endschema %}