<div class="categories-section">
  <div class="container">
    {% if section.settings.title != blank %}
      <div class="section-header">
        <h2 class="section-title">{{ section.settings.title }}</h2>
        <p class="section-subtitle">{{ section.settings.subtitle }}</p>
      </div>
    {% endif %}

    <div class="categories-grid">
      {% for block in section.blocks %}
        <a href="{{ block.settings.url | default: '/collections/all' }}" class="category-card" {{ block.shopify_attributes }}>
          <div class="category-image">
            {% if block.settings.image != blank %}
              <img src="{{ block.settings.image | img_url: 'medium' }}" alt="{{ block.settings.title | escape }}">
            {% else %}
              <div class="category-placeholder">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
                  <rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
                </svg>
              </div>
            {% endif %}
          </div>
          <h3 class="category-title">{{ block.settings.title }}</h3>
          {% if block.settings.count != blank %}
            <span class="category-count">{{ block.settings.count }} produtos</span>
          {% endif %}
        </a>
      {% endfor %}
    </div>
  </div>
</div>

<style>
  .categories-section {
    padding: 80px 0 60px;
    background: #fff;
  }
  .section-header {
    text-align: center;
    margin-bottom: 50px;
  }
  .section-title {
    font-size: 36px;
    font-weight: 800;
    color: #1a1a2e;
    margin-bottom: 10px;
  }
  .section-subtitle {
    font-size: 16px;
    color: #666;
  }
  .categories-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 25px;
  }
  .category-card {
    text-align: center;
    text-decoration: none;
    padding: 25px 15px;
    border-radius: 16px;
    background: #f8f9fa;
    transition: all 0.3s;
  }
  .category-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    background: #fff;
  }
  .category-image {
    width: 80px;
    height: 80px;
    margin: 0 auto 15px;
    border-radius: 50%;
    overflow: hidden;
    background: #e9ecef;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .category-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .category-placeholder {
    color: #999;
  }
  .category-title {
    font-size: 15px;
    font-weight: 700;
    color: #1a1a2e;
    margin-bottom: 5px;
  }
  .category-count {
    font-size: 12px;
    color: #999;
  }

  @media (max-width: 1024px) {
    .categories-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 768px) {
    .categories-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>

{% schema %}
{
  "name": "Categorias",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Comprar por Categoria"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "Encontre exactamente o que procura"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Categoria",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagem"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Nome",
          "default": "Categoria"
        },
        {
          "type": "text",
          "id": "count",
          "label": "Número de produtos"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link da categoria"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Categorias",
      "category": "Coleção",
      "blocks": [
        { "type": "category", "settings": { "title": "Moda" } },
        { "type": "category", "settings": { "title": "Electrónica" } },
        { "type": "category", "settings": { "title": "Beleza" } },
        { "type": "category", "settings": { "title": "Acessórios" } },
        { "type": "category", "settings": { "title": "Casa" } }
      ]
    }
  ]
}
{% endschema %}
