{% assign collection = collections[section.settings.collection] %}

{% if collection != blank %}
<div class="featured-products-section">
  <div class="container">
    <div class="section-header">
      {% if section.settings.title != blank %}
        <h2 class="section-title">{{ section.settings.title }}</h2>
      {% endif %}
      {% if section.settings.subtitle != blank %}
        <p class="section-subtitle">{{ section.settings.subtitle }}</p>
      {% endif %}
    </div>

    <div class="product-grid featured-grid">
      {% for product in collection.products limit: section.settings.products_count %}
        {% render 'product-card', product: product %}
      {% endfor %}
    </div>

    {% if section.settings.show_view_all %}
      <div class="section-footer">
        <a href="{{ collection.url }}" class="btn btn-outline">
          Ver Todos
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    {% endif %}
  </div>
</div>
{% else %}
<div class="featured-products-section">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">{{ section.settings.title | default: "Produtos em Destaque" }}</h2>
      <p class="section-subtitle">{{ section.settings.subtitle | default: "Os nossos melhores produtos seleccionados para si" }}</p>
    </div>
    <div class="product-grid featured-grid">
      {% for product in collections['all'].products limit: section.settings.products_count %}
        {% render 'product-card', product: product %}
      {% else %}
        <div class="empty-state">
          <svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="color: var(--color-text-muted); margin-bottom: 16px;">
            <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
            <line x1="3" y1="6" x2="21" y2="6"/>
            <path d="M16 10a4 4 0 0 1-8 0"/>
          </svg>
          <p>Adicione produtos na administração da loja para os ver aqui.</p>
        </div>
      {% endfor %}
    </div>
  </div>
</div>
{% endif %}

<style>
  .featured-products-section {
    padding: 90px 0;
    background: var(--color-bg);
  }

  .section-footer {
    text-align: center;
    margin-top: 50px;
  }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }

  .btn-outline svg {
    transition: transform 0.3s ease;
  }

  .btn-outline:hover svg {
    transform: translateX(5px);
  }

  .empty-state {
    grid-column: 1 / -1;
    text-align: center;
    padding: 80px 0;
    color: var(--color-text-light);
    background: #fff;
    border-radius: var(--radius-lg);
    border: 2px dashed var(--color-border);
  }

  @media (max-width: 1024px) {
    .product-grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 768px) {
    .product-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 480px) {
    .product-grid { grid-template-columns: 1fr; }
  }
</style>

{% schema %}
{
  "name": "Produtos em Destaque",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Coleção"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Produtos em Destaque"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "Os nossos melhores produtos seleccionados para si"
    },
    {
      "type": "range",
      "id": "products_count",
      "label": "Número de produtos",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 8
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Mostrar botão 'Ver Todos'",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Produtos em Destaque",
      "category": "Produtos"
    }
  ]
}
{% endschema %}